{
  "name": "nuxt-starter-kit",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier:fix": "prettier --write .",
    "check:types": "vue-tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "precommit": "lint-staged",
    "gen:sdk": "openapi-ts",
    "plop": "plop",
    "dep:check": "depcruise src --config .dependency-cruiser.cjs",
    "dep:report": "depcruise src --config .dependency-cruiser.cjs --output-type err-html --output-to docs/dependency-report.html",
    "dep:graph": "depcruise src --config .dependency-cruiser.cjs --output-type dot | dot -T svg > docs/dependency-graph.svg",
    "dep:graph:arch": "depcruise src --config .dependency-cruiser.cjs --output-type archi | dot -T svg > docs/architecture-graph.svg",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@sinclair/typebox": "^0.34.49",
    "@tanstack/vue-query": "^5.96.2",
    "@vee-validate/nuxt": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dayjs-nuxt": "^2.1.11",
    "jwt-decode": "^4.0.0",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.2",
    "ofetch": "^1.5.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.5",
    "tailwind-merge": "^3.5.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue3-toastify": "^0.2.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@hey-api/openapi-ts": "^0.95.0",
    "@nuxt/eslint": "^1.15.2",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@storybook/vue3-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/nuxt": "^14.2.1",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^20.9.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "plop": "^4.0.5",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "version": "1.0.0"
}
