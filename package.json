{
  "name": "nuxt-starter-kit",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier:fix": "prettier --write .",
    "check:types": "vue-tsc --noEmit",
    "precommit": "lint-staged",
    "gen:api": "openapi-typescript http://localhost:3100/docs/json -o src/common/api/generated/api-schema.ts",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@sinclair/typebox": "^0.34.49",
    "@tanstack/vue-query": "^5.96.2",
    "@vee-validate/nuxt": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dayjs-nuxt": "^2.1.11",
    "jwt-decode": "^4.0.0",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.2",
    "nuxt-typed-router": "^4.0.7",
    "ofetch": "^1.5.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.5",
    "tailwind-merge": "^3.5.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue3-toastify": "^0.2.9"
